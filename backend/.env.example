# ════════════════════════════════════════════════════════════════
#  .env.example — bu faylni .env ga nusxalab, qiymatlarni to'ldiring
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Django ───────────────────────────────────────────────────────
# Yangi kalit: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-SHUNING-O-RNIGA-YANGI-KALIT-YOZING

# Mahalliy: True | Server: False
DEBUG=False

# Domen va IP (vergul bilan, bo'shliqsiz)
ALLOWED_HOSTS=shajara.uz,www.shajara.uz,127.0.0.1

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL: postgres://USER:PAROL@HOST:5432/DB_NOMI
# Bo'sh qoldirilsa — SQLite (faqat mahalliy ishlatish uchun)
DATABASE_URL=postgres://shajara_user:PAROL@localhost:5432/shajara_db

# ── CORS ─────────────────────────────────────────────────────────
# Frontend domenlaringiz (vergul bilan, bo'shliqsiz)
CORS_ALLOWED_ORIGINS=https://shajara.uz,https://www.shajara.uz

# ── Telegram Bot ──────────────────────────────────────────────────
# @BotFather dan olingan token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Bot "Veb saytga o'tish" tugmasi uchun URL
WEB_BASE_URL=https://shajara.uz

# ── Web Push bildirnomalari (VAPID) ───────────────────────────────
# Yangi kalit generatsiya:
#   pip install py-vapid
#   vapid --gen
# Yoki: https://vapidkeys.com/
VAPID_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----\n
VAPID_PUBLIC_KEY=BIu63kTwBtznNP5mgXzy8TuoJ74FzuDHTfxzqCcg1FesfKJ4qLjKNHBIVk2GnLFlvETeRsvaCJZlFj7oMBFOO9o
VAPID_CLAIMS_EMAIL=admin@shajara.uz

# ── AI (ixtiyoriy) ────────────────────────────────────────────────
# Google Gemini (bepul): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (bepul fallback): https://console.groq.com/keys
GROQ_API_KEY=

# ── Cron job ──────────────────────────────────────────────────────
CRON_SECRET=o-zingiz-tanlaydigan-maxfiy-so-z
